# RePoChat Configuration

# Server settings
HOST=0.0.0.0
PORT=8000
DEBUG=true

# Database
DATABASE_URL=sqlite:///./repochat.db

# Default paths
DEFAULT_CLONE_PATH=C:/Users/%USERNAME%/repochat-projects

# AI Provider settings
DEFAULT_PROVIDER=openai

# Security
ENCRYPTION_KEY=your-encryption-key-here

# CORS
CORS_ORIGINS=["http://localhost:3000", "http://localhost:5173"]
